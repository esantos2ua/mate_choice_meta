# Quarto temporary directories (source-tree render artifacts).
# Keep the rendered figure folders that live under the published docs/ site,
# otherwise the GitHub Pages site would have broken images now that chapters
# are no longer self-contained.
*_files/
!/docs/**/*_files/

# Duplicate-file artifacts ("filename 2.ext", "dir 2") created during bulk
# writes (e.g. a full `quarto render`). Source unconfirmed, but never commit them.
* 2
* 2.*

