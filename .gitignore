# Quarto temporary directories (source-tree render artifacts).
# Keep the rendered figure folders that live under the published docs/ site,
# otherwise the GitHub Pages site would have broken images now that chapters
# are no longer self-contained.
*_files/
!/docs/**/*_files/

# Duplicate-file artifacts ("filename 2.ext", "dir 3", "name 4.map") created
# during bulk writes (e.g. a full `quarto render`) or cloud-sync conflicts.
# Source unconfirmed, but never commit them. Covers any " <n>" / " <nn>" suffix,
# with or without an extension.
* [0-9]
* [0-9].*
* [0-9][0-9]
* [0-9][0-9].*

# Python
__pycache__/
*.pyc

