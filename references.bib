@article{belkinaMateChoiceCopying2021,
  title = {Mate Choice Copying in Drosophila Is Probably Less Robust than Previously Suggested},
  author = {Belkina, Elena G. and Shiglik, Alexander and Sopilko, Natalia G. and Lysenkov, S. N. and Markov, Alexander V.},
  date = {2021},
  journaltitle = {Animal Behaviour},
  shortjournal = {Anim. Behav.},
  volume = {176},
  pages = {175--183},
  publisher = {NA},
  location = {NA},
  issn = {NA},
  doi = {10.1016/j.anbehav.2021.04.007},
  url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85106243092&doi=10.1016%2Fj.anbehav.2021.04.007&partnerID=40&md5=606b8e39552286762a205360e0573615},
  abstract = {Female mate choice copying is a form of social learning wherein females preferentially mate with partners similar to those they had previously observed mating with other females. The phenomenon is well established in many vertebrate species and some arthropods. Among insects, only one species, the fruit fly Drosophila melanogaster, has been shown to perform female mate choice copying under experimental conditions using two artificial male phenotypes (males dusted with powders of different colours). Moreover, this species has been shown to be capable of maintaining mate choice traditions, at least in laboratory conditions. In the present study, however, we failed to obtain unambiguous support for the claim that virgin female Drosophila (‘observers’) tend to prefer males of the same artificial phenotype as that chosen by another female (‘demonstrator’). The discrepancy is probably because our experiments differed in a number of seemingly minor details from the published experimental procedures. The results indicate that female mate choice copying in Drosophila is probably less robust than the present body of literature suggests, and that more research is needed to assess the prevalence of this phenomenon in different laboratory lines and natural populations of fruit flies. © 2021 The Association for the Study of Animal Behaviour | SCO\_04\_DaviesEtAlOriginalRayyanFormatted.csv; WoS\_01\_JonesDuvalOriginalRayyanFormatted.csv; WoS\_03\_DaviesEtAlOriginalRayyanFormatted.csv},
  langid = {english},
  keywords = {arthropod,Arthropoda,Drosophila melanogaster,fly,H...,laboratory method,mate choice,phenotype},
  file = {/Users/eduardosantos/Library/CloudStorage/GoogleDrive-esantos2@ualberta.ca/My Drive/ZotMoov/CopyingMetaAnalysisUpdate/FulltextScreeningPapers/Belkina et al. - 2021 - Mate choice copying in drosophila is probably less robust than previously suggested.pdf}
}

@article{bellInfluenceEarlylifeNutritional2018,
  title = {Influence of Early-Life Nutritional Stress on Songbird Memory Formation},
  author = {Bell, B. A. and Phan, M. L. and Meillere, A. and Evans, J. K. and Leitner, S. and Vicario, D. S. and Buchanan, Kate},
  date = {2018-09-26},
  eprint = {10536/DRO/DU:30114060},
  eprinttype = {hdl},
  url = {http://hdl.handle.net/10536/DRO/DU:30114060},
  abstract = {In birds, vocal learning enables the production of sexually selected complex songs, dialects and song copy matching. But stressful conditions during development have been shown to affect song production and complexity, mediated by changes in neural development. However, to date, no studies have tested whether early-life stress affects the neural processes underlying vocal learning, in contrast to song production. Here, we hypothesized that developmental stress alters auditory memory formation and neural processing of song stimuli. We experimentally stressed male nestling zebra finches and, in two separate experiments, tested their neural responses to song playbacks as adults, using either immediate early gene (IEG) expression or electrophysiological response. Once adult, nutritionally stressed males exhibited a reduced response to tutor song playback, as demonstrated by reduced expressions of two IEGs ( Arc and ZENK ) and reduced neuronal response, in both the caudomedial nidopallium (NCM) and mesopallium (CMM). Furthermore, nutritionally stressed males also showed impaired neuronal memory for novel songs heard in adulthood. These findings demonstrate, for the first time, that developmental conditions affect auditory memories that subserve vocal learning. Although the fitness consequences of such memory impairments remain to be determined, this study highlights the lasting impact early-life experiences can have on cognitive abilities.},
  langid = {english},
  keywords = {3209 Neurosciences,auditory,Biology,BIRDSONG,BRAIN-DEVELOPMENT,developmental stress,Ecology,electrophysiology,Environmental Sciences & Ecology,Evolutionary Biology,FOREBRAIN,GENE-EXPRESSION,HONEST SIGNAL,IEG,Life Sciences & Biomedicine,Life Sciences & Biomedicine - Other Topics,MATE CHOICE,RESPONSES,Science & Technology,SELECTION,SPATIAL MEMORY,vocal learning,zebra finch}
}

