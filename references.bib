@article{danchinCulturalFliesConformist2018,
  title = {Cultural Flies: Conformist Social Learning in Fruitflies Predicts Long-Lasting Mate-Choice Traditions},
  shorttitle = {Cultural Flies},
  author = {Danchin, Etienne and Nöbel, Sabine and Pocheville, Arnaud and Dagaeff, Anne-Cecile and Demay, Léa and Alphand, Mathilde and Ranty-Roby, Sarah and family=Renssen, given=Lara, prefix=van, useprefix=true and Monier, Magdalena and Gazagne, Eva and Allain, Mélanie and Isabel, Guillaume},
  date = {2018-11-30},
  journaltitle = {Science},
  shortjournal = {Science},
  volume = {362},
  number = {6418},
  pages = {1025--1030},
  publisher = {American Association for the Advancement of Science},
  doi = {10.1126/science.aat1590},
  url = {https://www.science.org/doi/10.1126/science.aat1590},
  urldate = {2026-02-03},
  abstract = {Despite theoretical justification for the evolution of animal culture, empirical evidence for it beyond mammals and birds remains scant, and we still know little about the process of cultural inheritance. In this study, we propose a mechanism-driven definition of animal culture and test it in the fruitfly. We found that fruitflies have five cognitive capacities that enable them to transmit mating preferences culturally across generations, potentially fostering persistent traditions (the main marker of culture) in mating preference. A transmission chain experiment validates a model of the emergence of local traditions, indicating that such social transmission may lead initially neutral traits to become adaptive, hence strongly selecting for copying and conformity. Although this situation was suggested decades ago, it previously had little empirical support.},
  langid = {english},
  annotation = {short-doi: 10/gfq734},
  file = {/Users/eduardosantos/Library/CloudStorage/GoogleDrive-esantos2@ualberta.ca/My Drive/ZotMoov/CopyingMetaAnalysisUpdate/BenchMarkSet/Danchin et al. - 2018 - Cultural flies conformist social learning in fruitflies predicts long-lasting mate-choice tradition.pdf}
}

@article{danelCrossculturalComparisonPopulationspecific2012,
  title = {A Cross-Cultural Comparison of Population-Specific Face Shape Preferences (Homo Sapiens)},
  author = {Danel, Dariusz and Fedurek, Paweł and Coetzee, Vinet and Stephen, Ian and Nowak, Natalia and Stirrat, Michael and Perrett, David and Saxton, Tamsin},
  date = {2012-12},
  eprint = {1893/29156},
  eprinttype = {hdl},
  publisher = {Wiley},
  url = {http://hdl.handle.net/1893/29156},
  abstract = {A substantial number of studies indicate that human facial features such as symmetry and averageness are preferred in human mate choice. Little is known, however, about face preferences in intrapopulation or between-cultural settings as only a few studies have addressed this topic. One hypothesis is that people prefer faces that resemble faces from their own population as a result of visual adaptation. Here, we present results of an internet-based experiment in which male and female participants from two European nations, Poland and Scotland, were asked to choose between 'Polish-modified' and 'Scottish-modified' faces (i.e. face portraits modified along one of ten different dimensions to resemble faces of the respective populations) of both sexes while being unaware of the origins of the portraits. The results show that the preferences of Polish judges for Polish-shaped faces were significantly stronger than the preferences of Scottish judges for the Scottish-shaped faces. Moreover, both Polish and Scottish judges preferred Polish-shaped faces to Scottish-shaped faces. These results suggest that natural visual experience acquired in everyday interpersonal interactions may have limited influence on aesthetic preferences in these particular intrapopulation settings.},
  langid = {english}
}

