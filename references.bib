  url = {https://arcabc.ca/islandora/object/unbc%3A16155},
  langid = {english},
  annotation = {Context Object: ctx\_ver=Z39.88-2004\&rft\_val\_fmt=info\%3Aofi\%2Ffmt\%3Akev\%3Amtx\%3Adc\&ctx\_enc=info\%3Aofi\%2Fenc\%3AUTF-8\&rfr\_id=info\%3Asid\%2F\%7Bhttps\%3A\%2F\%2Fwww.base-search.net\%7D\%3Agenerator\&rft\_id=https\%3A\%2F\%2Farcabc.ca\%2Fislandora\%2Fobject\%2Funbc\%253A16155\&rft.identifier=https\%3A\%2F\%2Farcabc.ca\%2Fislandora\%2Fobject\%2Funbc\%253A16155\&rft.type=thesis\&rft.title=The+signaling+function+of+plumage+characteristics+in+female+tree+swallows+and+implications+for+reproductive+success+and+life-history+decisions.\&rft.date=2011\&rft.pub=University+of+Northern+British+Columbia\&rft.language=English\&rft.rights=Copyright+retained+by+the+author.+\%3B+http\%3A\%2F\%2Frightsstatements.org\%2Fvocab\%2FInC\%2F1.0\%2F\&rft.description=The+existence+of+elaborate+plumages+in+birds+has+traditionally+been+explained+as+a+result+of+mate+choice+by+females+for+these+traits+in+males.+Ornate+plumage+traits+are+thought+to+be+costly+to+produce+and+maintain\%2C+allowing+females+to+gain+accurate+information+about+potential+mates+based+on+the+expression+of+these+traits.+Female+plumage+traits\%2C+on+the+other+hand\%2C+are+less+understood+and+have+been+rarely+studied+as+having+signaling+potential.+In+an+attempt+to+reduce+this+gap+in+knowledge\%2C+I+investigated+the+potential+signaling+function+of+specific+plumage+characteristics+in+female+tree+swallows+\%28Tachycineta+bicolor\%29.+Tree+swallows+are+one+of+only+two+species+of+North+American+passerines+where+females\%2C+rather+than+males\%2C+have+delayed+plumage+maturation+\%28DPM\%29.+Females+in+their+second+year+of+life+\%28SY\%29+display+mainly+brown+subadult-coloured\%27+feathers+on+their+dorsal+surface\%2C+while+older+\%28after-second+year+of+life\%3A+ASY\%29+females+primarily+have+iridescent+blue-green+adult-coloured\%27+feathers.+There+is\%2C+however\%2C+much+variation+in+the+number+of+adult-coloured+feathers+in+the+dorsal+plumage+of+SY+females.+To+date\%2C+only+one+study+has+experimentally+ex