@article{diazbastidaRevisionTeoricaFactores2016,
  title = {Revisión Teórica de Los Factores Externos de Influencia En La Formación de Parejas En La Adolescencia},
  author = {Diaz Bastida, Maria Dolores and Peñaranda Ortega, María},
  date = {2016},
  url = {https://dialnet.unirioja.es/servlet/oaiart?codigo=7428378},
  abstract = {In this paper, external factors wich influence mate choice during the adolescent stage are defined. Based on the physical characteristic of this phase to frame the start of attraction towards others, three basic aspects that shape the onset and course of romantic relationships will be exposed. First, the family, emphasizing attachment and parenting educational styles; the social area especially focused on relationships with peers in second place and finally the media, showing the role in the expansion of stereotypes and gender roles which can mark dating among teenagers ; En el presente artículo se definen los factores externos que influyen en la elección de pareja durante la etapa adolescente. Partiendo del desarrollo físico característico de esta fase para encuadrar el inicio de la atracción hacia los otros, se expondrán tres aspectos básicos que moldean el inicio y transcurso de las relaciones románticas. En primer lugar, el ámbito familiar, haciendo hincapié en el apego y los estilos parentales educativos; el área social especialmente enfocada en las relaciones con los iguales en segundo lugar y finalmente los medios de comunicación, mostrando el papel que juegan en la expansión de los estereotipos y roles de género y que pueden marcar el noviazgo entre los adolescentes},
  langid = {english},
  keywords = {Adolescence,Adolescencia,Amor,Búsquedade pareja,Couple,Love,Matchmaking,Pareja}
}

