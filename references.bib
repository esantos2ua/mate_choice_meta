@article{debruineHealthNationPredicts2010,
  title = {The Health of a Nation Predicts Their Mate Preferences: Cross-Cultural Variation in Women's Preferences for Masculinized Male Faces},
  shorttitle = {The Health of a Nation Predicts Their Mate Preferences},
  author = {DeBruine, Lisa M. and Jones, Benedict C. and Crawford, John R. and Welling, Lisa L. M. and Little, Anthony},
  date = {2010-08},
  eprint = {1893/17935},
  eprinttype = {hdl},
  publisher = {The Royal Society},
  url = {http://hdl.handle.net/1893/17935},
  abstract = {Recent formulations of sexual selection theory emphasize how mate choice can be affected by environmental factors, such as predation risk and resource quality. Women vary greatly in the extent to which they prefer male masculinity and this variation is hypothesized to reflect differences in how women resolve the trade-off between the costs (e.g. low investment) and benefits (e.g. healthy offspring) associated with choosing a masculine partner. A strong prediction of this trade-off theory is that women's masculinity preferences will be stronger in cultures where poor health is particularly harmful to survival. We investigated the relationship between women's preferences for male facial masculinity and a health index derived from World Health Organization statistics for mortality rates, life expectancies and the impact of communicable disease. Across 30 countries, masculinity preference increased as health decreased. This relationship was independent of cross-cultural differences in wealth or women's mating strategies. These findings show non-arbitrary cross-cultural differences in facial attractiveness judgements and demonstrate the use of trade-off theory for investigating cross-cultural variation in women's mate preferences.},
  langid = {english},
  keywords = {cross-cultural variation,health,masculinity,sexual selection}
}

@article{degrootQuickRobustMHC2017,
  title = {A Quick and Robust {{MHC}} Typing Method for Free-Ranging and Captive Primate Species},
  author = {family=Groot, given=N., prefix=de, useprefix=true and Stanbury, K. and family=Vos-Rouweler, given=A., prefix=de, useprefix=true and family=Groot, given=N., prefix=de, useprefix=true and Poirier, Nicolas and Blancho, G. and family=Luna, given=C., prefix=de, useprefix=true and Doxiadis, G. and Bontrop, R.},
  date = {2017},
  publisher = {HAL CCSD ; Springer Verlag},
  doi = {10.1007/s00251-016-0968-0},
  url = {https://inserm.hal.science/inserm-02156067},
  abstract = {International audience ; Gene products of the major histocompatibility complex (MHC) of human and non-human primates play a crucial role in adaptive immunity, and most of the relevant genes not only show a high degree of variability (polymorphism) but also copy number variation (CNV) is observed. Due to this diversity, MHC proteins influence the capability of individuals to cope with various pathogens. MHC and/or MHC-linked gene products such as odorant receptor genes are thought to influence mate choice and reproductive success. Therefore, MHC typing of wild and captive primate populations is considered to be useful in conservation biology, which is, however, often hampered by the need of invasive and time-consuming methods. All intact Mhc-DRB genes in primates appear to possess a complex and highly divergent microsatellite, DRB-STR. A panel of 154 pedigreed olive baboons (Papio anubis) was examined for their DRB content by DRB-STR analysis of genomic DNA. Using the same methodology on DNA of feces samples, DRB variability of a silvery gibbon population (Hylobates moloch) (N = 24), an endangered species, could successfully be studied. In both species, length determination of the DRB-STR resulted in the definition of unique genotyping patterns that appeared to be specific for a certain chromosome. Moreover, the different STR lengths were shown to segregate with the allelic variation of the respective gene. The results obtained expand data gained previously on DRB-STR typing in macaques, great apes, and humans and strengthen the conclusion that this protocol is applicable in molecular ecology, conservation biology, and colony management, especially of endangered primate species.},
  langid = {english},
  keywords = {[SDV.MHEP]Life Sciences [q-bio]/Human health and pathology,Animals,Animals [MeSH],Conservation biology,DNA Copy Number Variations,DNA Copy Number Variations [MeSH],Female,Female [MeSH],Genetic,Genotype,Genotype [MeSH],Humans,Humans [MeSH],Major Histocompatibility Complex,Major Histocompatibility Complex [MeSH],Male,Male [MeSH],MHC,Microsatellite Repeats,Microsatellite Repeats [MeSH],Microsatellites,Phylogeny,Phylogeny [MeSH],Polymorphism,Polymorphism Genetic [MeSH],Pre-clinical research,Primates,Primates [MeSH]},
  annotation = {short-doi: 10/f934w5}
}

