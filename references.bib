@article{lushaiButterflyDanausChrysippus2005,
  title = {The Butterfly Danaus Chrysippus ({{L}}.) in East {{Africa}} Comprises Polyphyletic, Sympatric Lineages That Are, despite Behavioural Isolation, Driven to Hybridization by Female-Biased Sex Ratios},
