@article{santosMatechoiceCopyingNonhuman2026,
  title = {Mate-Choice Copying in Non-Human Animals: Protocol for the Update of Two Meta-Analyses [{{Protocol}}]},
  shorttitle = {Mate-Choice Copying in Non-Human Animals},
  author = {Santos, Eduardo and Nakagawa, Shinichi and Lagisz, Malgorzata},
  date = {2026},
  journaltitle = {OSF},
  publisher = {OSF},
  doi = {10.17605/OSF.IO/VFAHK},
  url = {https://osf.io/vfahk},
  abstract = {This research project updates two meta-analyses (Jones \& DuVal, 2019; Davies et al., 2020) to refine the scientific understanding of mate-choice copying in non-human animals. This phenomenon, in which an individual’s mating preference is influenced by observing others' choices, is a driver of sexual selection, yet current syntheses require modernization. The project’s purpose is to integrate empirical data published since 2019, including multilingual studies from databases like SciELO and Google Scholar. By applying the PECOS framework and advanced multilevel analytical models, we aim to minimize bias and enhance not only the taxonomic, but also the amplitude of the evidence base. Expected outcomes include updated global effect size estimates (Odds Ratio and Hedges’ d) and a detailed analysis of how factors like phylogeny and study design influence copying behavior. Ultimately, this work will provide a transparent, rigorous standard of evidence, advancing evolutionary biology through open science and updated methodology.},
  langid = {english},
  file = {/Users/eduardosantos/Zotero/storage/ISRX6GVS/vfahk.html}
}

