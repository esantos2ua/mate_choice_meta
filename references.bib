@article{kleisnerHowWhyPatterns2021,
  title = {How and Why Patterns of Sexual Dimorphism in Human Faces Vary across the World},
  author = {Kleisner, Karel and Tureček, Petr and Roberts, S. Craig and Havlíček, Jan and Valentova, Jaroslava Varella and Akoko, Robert Mbe and Leongómez, Juan David and Apostol, Silviu and Varella, Marco A. C. and Saribay, S. Adil},
