@article{perezmanriqueEffectsEarlySocial2006,
  title = {Effects of Early Social Experiences on Mating Preferences of Coturnix Japonica. ; Efectos de La Experiencia Social Temprana En Las Preferencias Sexuales de La Codorniz Japonesa (Coturnix Japonica)},
  author = {Pérez Manrique, Tiberio and Gutierrez, Germán},
